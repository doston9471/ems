# Copy to secret.yaml and fill in real values. Do not commit secret.yaml.
apiVersion: v1
kind: Secret
metadata:
  name: ems-secrets
  namespace: ems
type: Opaque
stringData:
  SECRET_KEY_BASE: "replace-with-rails-secret-key-base"
  RAILS_MASTER_KEY: "replace-with-config-master-key"
  POSTGRES_USER: "ems"
  POSTGRES_PASSWORD: "replace-with-strong-password"
  DATABASE_URL: "postgres://ems:replace-with-strong-password@ems-postgres:5432/employee_management_system_production"
