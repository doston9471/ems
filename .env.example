# Copy to .env and fill in secrets for local / Docker use.
# cp .env.example .env

RAILS_ENV=development
RAILS_MASTER_KEY=replace_with_config_master_key
SECRET_KEY_BASE=replace_with_long_random_hex

# Local brew Postgres (often trust auth, OS user, no password)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
DATABASE_URL=postgres://localhost:5432/employee_management_system_development

# Docker Compose Postgres
POSTGRES_USER=ems
POSTGRES_PASSWORD=ems
POSTGRES_DB=employee_management_system_development
POSTGRES_PORT=5432
WEB_PORT=3000
NGINX_PORT=8080

# Optional OAuth — leave blank for local password-only login.
# Callback URLs: http://localhost:3000/auth/google_oauth2/callback
#                http://localhost:3000/auth/github/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# MFA (TOTP) uses rotp; no extra env required. Issuer label is "EMS".
# Optional app host used in mailer links:
# APP_HOST=localhost:3000

# Optional notification integrations (company settings UI can override)
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Calendar OAuth (Google Calendar / Microsoft Graph). Falls back to GOOGLE_CLIENT_* for Google.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
# Optional overrides (default to Google/Graph production endpoints):
# GOOGLE_CALENDAR_API_BASE=https://www.googleapis.com/calendar/v3
# GOOGLE_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_CALENDAR_STUB=

OUTLOOK_CALENDAR_CLIENT_ID=
OUTLOOK_CALENDAR_CLIENT_SECRET=
OUTLOOK_CALENDAR_TENANT=common
# OUTLOOK_CALENDAR_API_BASE=https://graph.microsoft.com/v1.0
OUTLOOK_CALENDAR_STUB=

# Callback URLs (register in Google/Azure consoles):
# http://localhost:3000/calendar_oauth/google/callback
# http://localhost:3000/calendar_oauth/outlook/callback
# http://localhost:3000/sso/oidc/callback
# http://localhost:3000/sso/saml/callback
