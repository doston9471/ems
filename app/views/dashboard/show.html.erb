<% content_for :head do %>
  <%= javascript_include_tag "chart.umd", defer: true, "data-turbo-track": "reload" %>
<% end %>

<div class="space-y-6">
  <% unless current_user.email_verified? %>
    <div class="rounded-md border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-950">
      <%= t("dashboard.verify_email") %>
      <%= button_to t("dashboard.resend_verification"), email_verification_path, method: :post, class: "ml-1 font-medium text-amber-900 underline hover:no-underline inline cursor-pointer bg-transparent border-0 p-0" %>
    </div>
  <% end %>

  <div>
    <h1 class="text-2xl font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("dashboard.subtitle", company: current_company.name) %></p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("dashboard.employees") %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white"><%= @widgets[:employees_count] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("dashboard.present_today") %></p>
      <p class="mt-2 text-3xl font-semibold text-teal-700"><%= @widgets[:present_today] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("dashboard.on_leave") %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white"><%= @widgets[:on_leave] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs font-medium uppercase tracking-wide text-slate-500"><%= t("dashboard.birthdays_week") %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white"><%= @widgets[:birthdays_this_week].size %></p>
    </div>
  </div>

  <div
    class="grid gap-6 lg:grid-cols-2"
    data-controller="dashboard-charts"
    data-dashboard-charts-department-value="<%= h @charts[:headcount_by_department].to_json %>"
    data-dashboard-charts-status-value="<%= h @charts[:employment_status].to_json %>"
    data-dashboard-charts-attendance-value="<%= h @charts[:attendance_trend].to_json %>"
    data-dashboard-charts-leave-value="<%= h @charts[:leave_pipeline].to_json %>"
    data-dashboard-charts-employees-label-value="<%= t('dashboard.chart_employees') %>"
    data-dashboard-charts-present-label-value="<%= t('dashboard.chart_present') %>"
  >
    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.headcount_by_department") %></h2>
      <div class="relative mt-4 h-64">
        <% if @charts[:headcount_by_department][:labels].any? %>
          <canvas data-dashboard-charts-target="department" aria-label="<%= t("dashboard.headcount_by_department") %>"></canvas>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("dashboard.no_employees_chart") %></p>
        <% end %>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.employment_status") %></h2>
      <div class="relative mt-4 h-64">
        <% if @charts[:employment_status][:values].sum.positive? %>
          <canvas data-dashboard-charts-target="status" aria-label="<%= t("dashboard.employment_status") %>"></canvas>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("dashboard.no_status_data") %></p>
        <% end %>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.attendance_14_days") %></h2>
      <div class="relative mt-4 h-64">
        <canvas data-dashboard-charts-target="attendance" aria-label="<%= t("dashboard.attendance_14_days") %>"></canvas>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.leave_pipeline") %></h2>
      <div class="relative mt-4 h-64">
        <% if @charts[:leave_pipeline][:values].sum.positive? %>
          <canvas data-dashboard-charts-target="leave" aria-label="<%= t("dashboard.leave_pipeline") %>"></canvas>
        <% else %>
          <p class="text-sm text-slate-500"><%= t("dashboard.no_leave_yet") %></p>
        <% end %>
      </div>
    </section>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.recent_hires") %></h2>
      <% if @widgets[:recent_hires].any? %>
        <ul class="mt-4 divide-y divide-slate-100 dark:divide-slate-800">
          <% @widgets[:recent_hires].each do |employee| %>
            <li class="flex items-center justify-between py-3 text-sm">
              <%= link_to employee.full_name, employee_path(employee), class: "font-medium text-teal-700 hover:text-teal-800" %>
              <span class="text-slate-500"><%= employee.joining_date %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-4 text-sm text-slate-500"><%= t("dashboard.no_recent_hires") %></p>
      <% end %>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= t("dashboard.birthdays_week") %></h2>
      <% if @widgets[:birthdays_this_week].any? %>
        <ul class="mt-4 divide-y divide-slate-100 dark:divide-slate-800">
          <% @widgets[:birthdays_this_week].each do |employee| %>
            <li class="flex items-center justify-between py-3 text-sm">
              <span class="font-medium text-slate-800 dark:text-slate-100"><%= employee.full_name %></span>
              <span class="text-slate-500"><%= employee.birthday&.strftime("%b %d") %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="mt-4 text-sm text-slate-500"><%= t("dashboard.no_birthdays") %></p>
      <% end %>
    </section>
  </div>
</div>
