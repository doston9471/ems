<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900">New goal</h1>

  <%= form_with model: @goal, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if @goal.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= @goal.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :employee_id, "Employee", class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :employee_id, @employees, :id, :full_name, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :title, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :description, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_area :description, rows: 3, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :target_date, class: "block text-sm font-medium text-slate-700" %>
        <%= f.date_field :target_date, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :progress_percent, "Progress %", class: "block text-sm font-medium text-slate-700" %>
        <%= f.number_field :progress_percent, min: 0, max: 100, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div>
      <%= f.label :status, class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :status, Goal.statuses.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Create goal", class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to "Cancel", goals_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
