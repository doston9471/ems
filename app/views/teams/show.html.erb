<div class="mx-auto max-w-3xl space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= @team.name %></h1>
      <p class="mt-1 text-sm text-slate-500">
        <%= @team.department&.name || t("teams.show.no_department") %>
        · <%= t("teams.show.lead", name: (@team.lead_employee&.full_name || t("common.empty_value"))) %>
      </p>
    </div>
    <% if policy(@team).update? %>
      <%= link_to t("common.edit"), edit_team_path(@team), class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    <% end %>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900"><%= t("common.members") %></h2>
    <ul class="mt-3 divide-y divide-slate-100 text-sm">
      <% @members.each do |employee| %>
        <li class="py-2"><%= link_to employee.full_name, employee_path(employee), class: "text-teal-700 hover:text-teal-800" %></li>
      <% end %>
    </ul>
    <% if @members.empty? %>
      <p class="mt-3 text-sm text-slate-500"><%= t("teams.show.no_members") %></p>
    <% end %>
  </section>

  <p><%= link_to t("teams.show.back"), teams_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
