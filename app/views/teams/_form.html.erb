<div class="mx-auto max-w-2xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= title %></h1>

  <%= form_with model: team, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if team.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= team.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :department_id, t("common.department"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :department_id, @departments, :id, :name, { include_blank: true }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :lead_employee_id, t("common.lead"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :lead_employee_id, @employees, :id, :full_name, { include_blank: true }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <p class="mb-2 text-sm font-medium text-slate-700"><%= t("common.members") %></p>
      <div class="max-h-48 space-y-2 overflow-y-auto rounded-md border border-slate-200 p-3">
        <% selected = team.persisted? ? team.employee_ids : [] %>
        <% @employees.each do |employee| %>
          <label class="flex items-center gap-2 text-sm">
            <input type="checkbox" name="team[employee_ids][]" value="<%= employee.id %>"
                   class="rounded border-slate-300 text-teal-700"
                   <%= "checked" if selected.include?(employee.id) %>>
            <%= employee.full_name %>
          </label>
        <% end %>
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("common.cancel"), teams_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
