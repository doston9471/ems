<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900">Teams</h1>
      <p class="mt-1 text-sm text-slate-500">Team structure for <%= current_company.name %></p>
    </div>
    <% if policy(Team).create? %>
      <%= link_to "New team", new_team_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Department</th>
          <th class="px-4 py-3">Lead</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @teams.each do |team| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= link_to team.name, team_path(team), class: "font-medium text-teal-700 hover:text-teal-800" %></td>
            <td class="px-4 py-3"><%= team.department&.name || "—" %></td>
            <td class="px-4 py-3"><%= team.lead_employee&.full_name || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @teams.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500">No teams yet.</p>
    <% end %>
  </div>
</div>
