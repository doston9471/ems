<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("performance.index.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("performance.index.subtitle") %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to t("performance.index.reviews"), performance_reviews_path, class: "inline-flex rounded-md border border-slate-300 px-3.5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      <%= link_to t("performance.index.goals"), goals_path, class: "inline-flex rounded-md border border-slate-300 px-3.5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      <% if policy(ReviewCycle).create? %>
        <%= link_to t("performance.index.start_cycle"), new_review_cycle_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
      <% end %>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.name") %></th>
          <th class="px-4 py-3"><%= t("common.kind") %></th>
          <th class="px-4 py-3"><%= t("common.period") %></th>
          <th class="px-4 py-3"><%= t("common.status") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @review_cycles.each do |cycle| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= link_to cycle.name, review_cycle_path(cycle), class: "font-medium text-teal-700 hover:text-teal-800" %></td>
            <td class="px-4 py-3"><%= cycle.kind.humanize %></td>
            <td class="px-4 py-3 text-slate-600"><%= cycle.period_start %> → <%= cycle.period_end %></td>
            <td class="px-4 py-3"><%= cycle.status.humanize %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @review_cycles.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("performance.index.empty") %></p>
    <% end %>
  </div>
</div>
