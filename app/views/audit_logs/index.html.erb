<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("audit.index.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("audit.index.subtitle") %></p>
  </div>

  <%= form_with url: audit_logs_path, method: :get, class: "flex flex-wrap items-end gap-3" do %>
    <div>
      <label class="block text-sm font-medium text-slate-700" for="auditable_type"><%= t("common.type") %></label>
      <select name="auditable_type" id="auditable_type" class="mt-1 block rounded-md border border-slate-300 px-3 py-2 text-sm">
        <option value=""><%= t("common.all") %></option>
        <% @auditable_types.each do |type| %>
          <option value="<%= type %>" <%= "selected" if params[:auditable_type] == type %>><%= type %></option>
        <% end %>
      </select>
    </div>
    <button type="submit" class="rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600"><%= t("common.filter") %></button>
  <% end %>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.when") %></th>
          <th class="px-4 py-3"><%= t("common.type") %></th>
          <th class="px-4 py-3"><%= t("common.action") %></th>
          <th class="px-4 py-3"><%= t("common.user") %></th>
          <th class="px-4 py-3"><%= t("common.changes") %></th>
          <th class="px-4 py-3"><%= t("common.ip") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @audit_logs.each do |log| %>
          <tr class="hover:bg-slate-50 align-top">
            <td class="px-4 py-3 whitespace-nowrap text-slate-600"><%= log.created_at.strftime("%Y-%m-%d %H:%M") %></td>
            <td class="px-4 py-3"><%= log.auditable_type %>#<%= log.auditable_id %></td>
            <td class="px-4 py-3"><%= log.action %></td>
            <td class="px-4 py-3"><%= log.user&.full_name || t("common.empty_value") %></td>
            <td class="px-4 py-3 max-w-xs truncate text-slate-600" title="<%= log.changes_data.to_json %>">
              <%= log.changes_data.present? ? log.changes_data.keys.join(", ") : t("common.empty_value") %>
            </td>
            <td class="px-4 py-3 text-slate-600"><%= log.ip_address.presence || t("common.empty_value") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @audit_logs.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("audit.index.empty") %></p>
    <% end %>
  </div>

  <% if @pagy && @pagy.pages > 1 %>
    <div class="flex items-center justify-between text-sm text-slate-600">
      <span><%= t("audit.index.page", page: @pagy.page, total: @pagy.pages) %></span>
      <div class="flex gap-2">
        <% if @pagy.previous %>
          <%= link_to t("common.previous"), audit_logs_path(page: @pagy.previous, auditable_type: params[:auditable_type]), class: "text-teal-700 hover:text-teal-800" %>
        <% end %>
        <% if @pagy.next %>
          <%= link_to t("common.next"), audit_logs_path(page: @pagy.next, auditable_type: params[:auditable_type]), class: "text-teal-700 hover:text-teal-800" %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
