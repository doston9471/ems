<div class="mx-auto max-w-2xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= title %></h1>

  <%= form_with model: employee, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if employee.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= employee.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :employee_number, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :employee_number, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :employment_status, class: "block text-sm font-medium text-slate-700" %>
        <%= f.select :employment_status, Employee.employment_statuses.keys.map { |s| [s.humanize, s] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :first_name, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :first_name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :last_name, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :last_name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :email, class: "block text-sm font-medium text-slate-700" %>
        <%= f.email_field :email, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :job_title, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :job_title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :joining_date, class: "block text-sm font-medium text-slate-700" %>
        <%= f.date_field :joining_date, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :department_id, t("employees.form.department"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.collection_select :department_id, @departments, :id, :name, { include_blank: true }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :office_id, t("employees.form.office"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.collection_select :office_id, @offices, :id, :name, { include_blank: true }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :manager_id, t("employees.form.manager"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.collection_select :manager_id, @managers, :id, :full_name, { include_blank: true }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :salary, t("employees.form.salary"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.number_field :salary, value: employee.salary, step: 0.01, min: 0, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
        <p class="mt-1 text-xs text-slate-500"><%= t("employees.form.salary_hint") %></p>
      </div>
      <div>
        <%= f.label :currency, class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :currency, maxlength: 3, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm uppercase" %>
      </div>
    </div>

    <% if @custom_field_definitions.present? %>
      <div class="space-y-3 border-t border-slate-100 pt-4">
        <p class="text-sm font-medium text-slate-800"><%= t("employees.form.custom_fields") %></p>
        <div class="grid gap-4 sm:grid-cols-2">
          <% @custom_field_definitions.each do |definition| %>
            <% current = @custom_field_values[definition.id]&.value %>
            <div>
              <label class="block text-sm font-medium text-slate-700" for="custom_field_<%= definition.id %>"><%= definition.label %><% if definition.required %> *<% end %></label>
              <% case definition.field_type %>
              <% when "boolean" %>
                <%= select_tag "custom_fields[#{definition.id}]", options_for_select([[t("common.no"), "false"], [t("common.yes"), "true"]], current), include_blank: !definition.required, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", id: "custom_field_#{definition.id}" %>
              <% when "date" %>
                <%= date_field_tag "custom_fields[#{definition.id}]", current, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", id: "custom_field_#{definition.id}" %>
              <% when "number" %>
                <%= number_field_tag "custom_fields[#{definition.id}]", current, step: "any", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", id: "custom_field_#{definition.id}" %>
              <% when "select" %>
                <%= select_tag "custom_fields[#{definition.id}]", options_for_select(Array(definition.options["choices"]), current), include_blank: !definition.required, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", id: "custom_field_#{definition.id}" %>
              <% else %>
                <%= text_field_tag "custom_fields[#{definition.id}]", current, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm", id: "custom_field_#{definition.id}" %>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex gap-3 pt-2">
      <%= f.submit class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("employees.form.cancel"), employees_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
