<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900">New asset</h1>

  <%= form_with model: @company_asset, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if @company_asset.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= @company_asset.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :asset_type, class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :asset_type, CompanyAsset.asset_types.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :serial_number, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :serial_number, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :purchased_on, class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :purchased_on, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :notes, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit "Create asset", class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to "Cancel", company_assets_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
