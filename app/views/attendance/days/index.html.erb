<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900">Attendance</h1>
      <p class="mt-1 text-sm text-slate-500">Daily summary for <%= @summary[:date] %></p>
    </div>
    <% if Current.employee && policy(AttendanceDay).create? %>
      <div class="flex flex-wrap gap-2">
        <%= button_to "Clock in", clock_in_attendance_days_path, method: :post, class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
        <%= button_to "Clock out", clock_out_attendance_days_path, method: :post, class: "rounded-md bg-slate-800 px-3.5 py-2 text-sm font-medium text-white hover:bg-slate-700" %>
        <%= button_to "Break start", break_start_attendance_days_path, method: :post, class: "rounded-md border border-slate-300 px-3.5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
        <%= button_to "Break end", break_end_attendance_days_path, method: :post, class: "rounded-md border border-slate-300 px-3.5 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
      </div>
    <% end %>
  </div>

  <% if @today %>
    <div class="rounded-lg border border-teal-200 bg-teal-50 px-4 py-3 text-sm text-teal-900">
      Today: <%= @today.status.humanize %>
      <% if @today.clock_in_at %>· In <%= l(@today.clock_in_at, format: :short) %><% end %>
      <% if @today.clock_out_at %>· Out <%= l(@today.clock_out_at, format: :short) %><% end %>
    </div>
  <% end %>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Records today</p>
      <p class="mt-1 text-2xl font-semibold"><%= @summary[:total] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Complete</p>
      <p class="mt-1 text-2xl font-semibold"><%= @summary[:complete] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Open</p>
      <p class="mt-1 text-2xl font-semibold"><%= @summary[:open] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-4">
      <p class="text-xs uppercase tracking-wide text-slate-500">Week worked (hrs)</p>
      <p class="mt-1 text-2xl font-semibold"><%= (@weekly[:worked_minutes] / 60.0).round(1) %></p>
    </div>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3">Date</th>
          <th class="px-4 py-3">Employee</th>
          <th class="px-4 py-3">In</th>
          <th class="px-4 py-3">Out</th>
          <th class="px-4 py-3">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @days.each do |day| %>
          <tr>
            <td class="px-4 py-3"><%= day.work_date %></td>
            <td class="px-4 py-3"><%= day.employee.full_name %></td>
            <td class="px-4 py-3 text-slate-600"><%= day.clock_in_at&.strftime("%H:%M") || "—" %></td>
            <td class="px-4 py-3 text-slate-600"><%= day.clock_out_at&.strftime("%H:%M") || "—" %></td>
            <td class="px-4 py-3"><%= day.status.humanize %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
