<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("payroll.index.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("payroll.index.subtitle") %></p>
    </div>
    <% if policy(PayrollRun).create? %>
      <%= link_to t("payroll.index.generate"), new_payroll_run_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.period") %></th>
          <th class="px-4 py-3"><%= t("common.status") %></th>
          <th class="px-4 py-3"><%= t("payroll.index.generated") %></th>
          <th class="px-4 py-3"><%= t("payroll.index.items") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @payroll_runs.each do |run| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3">
              <%= link_to "#{run.period_start} → #{run.period_end}", payroll_run_path(run), class: "font-medium text-teal-700 hover:text-teal-800" %>
            </td>
            <td class="px-4 py-3">
              <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700"><%= run.status.humanize %></span>
            </td>
            <td class="px-4 py-3 text-slate-600"><%= run.generated_at&.strftime("%Y-%m-%d %H:%M") || t("common.empty_value") %></td>
            <td class="px-4 py-3"><%= run.payroll_items.size %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @payroll_runs.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("payroll.index.empty") %></p>
    <% end %>
  </div>
</div>
