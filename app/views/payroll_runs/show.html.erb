<div class="mx-auto max-w-4xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">Payroll run</h1>
    <p class="mt-1 text-sm text-slate-500">
      <%= @payroll_run.period_start %> → <%= @payroll_run.period_end %>
      · <%= @payroll_run.status.humanize %>
    </p>
  </div>

  <dl class="grid gap-4 rounded-lg border border-slate-200 bg-white p-5 sm:grid-cols-3 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Generated at</dt>
      <dd class="mt-1"><%= @payroll_run.generated_at&.strftime("%Y-%m-%d %H:%M") || "—" %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Employees</dt>
      <dd class="mt-1"><%= @payroll_items.size %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Total net</dt>
      <dd class="mt-1">
        <%= number_to_currency(@payroll_items.sum(&:net_cents) / 100.0, unit: (@payroll_items.first&.currency || Current.company.currency) + " ") %>
      </dd>
    </div>
  </dl>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3">Employee</th>
          <th class="px-4 py-3">Salary</th>
          <th class="px-4 py-3">Tax</th>
          <th class="px-4 py-3">Insurance</th>
          <th class="px-4 py-3">Net</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @payroll_items.each do |item| %>
          <tr>
            <td class="px-4 py-3 font-medium text-slate-900"><%= item.employee.full_name %></td>
            <td class="px-4 py-3"><%= number_to_currency(item.salary_cents / 100.0) %></td>
            <td class="px-4 py-3"><%= number_to_currency(item.tax_cents / 100.0) %></td>
            <td class="px-4 py-3"><%= number_to_currency(item.insurance_cents / 100.0) %></td>
            <td class="px-4 py-3 font-medium"><%= number_to_currency(item.net_cents / 100.0) %></td>
            <td class="px-4 py-3 text-right">
              <% if policy(item).show? %>
                <%= link_to "PDF", payroll_item_path(item, format: :pdf), class: "text-teal-700 hover:text-teal-800" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @payroll_items.empty? %>
      <p class="px-4 py-6 text-center text-sm text-slate-500">No payroll items.</p>
    <% end %>
  </div>

  <p><%= link_to "← All payroll runs", payroll_runs_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
