<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= t("payroll.new.title") %></h1>

  <%= form_with model: @payroll_run, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if @payroll_run.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= @payroll_run.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :period_start, class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :period_start, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :period_end, class: "block text-sm font-medium text-slate-700" %>
      <%= f.date_field :period_end, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit t("payroll.new.submit"), class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("common.cancel"), payroll_runs_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
