<div class="mx-auto max-w-3xl space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= @office.name %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= @office.code.presence || "No code" %> · <%= @office.timezone.presence || "No timezone" %></p>
    </div>
    <% if policy(@office).update? %>
      <%= link_to "Edit", edit_office_path(@office), class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    <% end %>
  </div>

  <dl class="grid gap-4 rounded-lg border border-slate-200 bg-white p-5 sm:grid-cols-2 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Address</dt>
      <dd class="mt-1"><%= [@office.address_line1, @office.city, @office.country].compact_blank.join(", ").presence || "—" %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Active</dt>
      <dd class="mt-1"><%= @office.active? ? "Yes" : "No" %></dd>
    </div>
  </dl>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900">Employees</h2>
    <ul class="mt-3 divide-y divide-slate-100 text-sm">
      <% @employees.each do |employee| %>
        <li class="py-2"><%= link_to employee.full_name, employee_path(employee), class: "text-teal-700 hover:text-teal-800" %></li>
      <% end %>
    </ul>
    <% if @employees.empty? %>
      <p class="mt-3 text-sm text-slate-500">No employees assigned.</p>
    <% end %>
  </section>

  <p><%= link_to "← All offices", offices_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
