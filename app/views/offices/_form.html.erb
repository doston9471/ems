<div class="mx-auto max-w-2xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= title %></h1>

  <%= form_with model: office, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if office.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= office.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= f.label :name, t("common.name"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :code, t("common.code"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :code, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :timezone, t("common.timezone"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :timezone, placeholder: t("offices.form.timezone_placeholder"), class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :address_line1, t("common.address"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :address_line1, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :city, t("common.city"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :city, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :country, t("common.country"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :country, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div class="sm:col-span-2">
        <label class="inline-flex items-center gap-2 text-sm">
          <%= f.check_box :active, class: "rounded border-slate-300 text-teal-700" %>
          <%= t("common.active") %>
        </label>
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit t(office.persisted? ? "offices.form.update" : "offices.form.create"), class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("common.cancel"), offices_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
