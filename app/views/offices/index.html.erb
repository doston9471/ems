<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900">Offices</h1>
      <p class="mt-1 text-sm text-slate-500">Locations for <%= current_company.name %></p>
    </div>
    <% if policy(Office).create? %>
      <%= link_to "New office", new_office_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3">Name</th>
          <th class="px-4 py-3">Code</th>
          <th class="px-4 py-3">City</th>
          <th class="px-4 py-3">Timezone</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @offices.each do |office| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= link_to office.name, office_path(office), class: "font-medium text-teal-700 hover:text-teal-800" %></td>
            <td class="px-4 py-3 font-mono text-xs"><%= office.code.presence || "—" %></td>
            <td class="px-4 py-3"><%= [office.city, office.country].compact_blank.join(", ").presence || "—" %></td>
            <td class="px-4 py-3"><%= office.timezone.presence || "—" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @offices.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500">No offices yet.</p>
    <% end %>
  </div>
</div>
