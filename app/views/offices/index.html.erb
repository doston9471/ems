<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("offices.index.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("offices.index.subtitle", company: current_company.name) %></p>
    </div>
    <% if policy(Office).create? %>
      <%= link_to t("offices.index.new"), new_office_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.name") %></th>
          <th class="px-4 py-3"><%= t("common.code") %></th>
          <th class="px-4 py-3"><%= t("common.city") %></th>
          <th class="px-4 py-3"><%= t("common.timezone") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @offices.each do |office| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= link_to office.name, office_path(office), class: "font-medium text-teal-700 hover:text-teal-800" %></td>
            <td class="px-4 py-3 font-mono text-xs"><%= office.code.presence || t("common.empty_value") %></td>
            <td class="px-4 py-3"><%= [office.city, office.country].compact_blank.join(", ").presence || t("common.empty_value") %></td>
            <td class="px-4 py-3"><%= office.timezone.presence || t("common.empty_value") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @offices.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("offices.index.empty") %></p>
    <% end %>
  </div>
</div>
