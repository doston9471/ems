<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= t("recruitment.new.title") %></h1>

  <%= form_with model: @applicant, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if @applicant.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= @applicant.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :first_name, t("common.first_name"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :first_name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :last_name, t("common.last_name"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.text_field :last_name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div>
      <%= f.label :email, t("common.email"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.email_field :email, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :phone, t("common.phone"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.telephone_field :phone, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :job_title, t("common.job_title"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :job_title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :department_id, t("common.department"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :department_id, @departments, :id, :name, { include_blank: t("common.empty_value") }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :stage, t("common.stage"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :stage, Applicant.stages.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :notes, t("common.notes"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit t("recruitment.new.submit"), class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("common.cancel"), applicants_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
