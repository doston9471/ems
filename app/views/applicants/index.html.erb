<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("recruitment.index.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("recruitment.index.subtitle") %></p>
    </div>
    <% if policy(Applicant).create? %>
      <%= link_to t("recruitment.index.new"), new_applicant_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.name") %></th>
          <th class="px-4 py-3"><%= t("common.role") %></th>
          <th class="px-4 py-3"><%= t("common.department") %></th>
          <th class="px-4 py-3"><%= t("common.stage") %></th>
          <th class="px-4 py-3"><%= t("common.email") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @applicants.each do |applicant| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3">
              <%= link_to applicant.full_name, applicant_path(applicant), class: "font-medium text-teal-700 hover:text-teal-800" %>
            </td>
            <td class="px-4 py-3"><%= applicant.job_title.presence || t("common.empty_value") %></td>
            <td class="px-4 py-3"><%= applicant.department&.name || t("common.empty_value") %></td>
            <td class="px-4 py-3">
              <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700"><%= applicant.stage.humanize %></span>
            </td>
            <td class="px-4 py-3 text-slate-600"><%= applicant.email %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @applicants.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("recruitment.index.empty") %></p>
    <% end %>
  </div>
</div>
