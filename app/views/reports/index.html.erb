<% content_for :title, t("nav.reports") %>

<div class="space-y-8" data-controller="reports-charts">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900 dark:text-slate-100"><%= t("nav.reports") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("reports.index.subtitle") %></p>
    </div>
    <div class="flex flex-wrap gap-2 text-sm">
      <%= link_to t("common.csv"), reports_employees_path(format: :csv), class: "rounded-md bg-slate-900 px-3 py-2 text-white hover:bg-slate-800 dark:bg-teal-700" %>
      <%= link_to t("common.excel"), reports_employees_path(format: :xlsx), class: "rounded-md border border-slate-300 px-3 py-2 text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:text-slate-200" %>
      <%= link_to t("common.pdf"), reports_employees_path(format: :pdf), class: "rounded-md border border-slate-300 px-3 py-2 text-slate-700 hover:bg-slate-50 dark:border-slate-600 dark:text-slate-200" %>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("reports.index.headcount") %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white"><%= @headcount[:total] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("reports.index.attendance_30d") %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white"><%= @attendance[:total_days] %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("reports.index.avg_salary") %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white">$<%= number_with_delimiter((@salary[:average_cents] / 100.0).round) %></p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("reports.index.attrition", year: @attrition[:year]) %></p>
      <p class="mt-2 text-3xl font-semibold text-slate-900 dark:text-white"><%= @attrition[:attrition_rate_pct] %>%</p>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-100"><%= t("reports.index.headcount_by_department") %></h2>
      <div class="mt-4 space-y-3">
        <% max = [@headcount[:by_department].values.max.to_i, 1].max %>
        <% @headcount[:by_department].each do |name, count| %>
          <div>
            <div class="mb-1 flex justify-between text-xs text-slate-600 dark:text-slate-400">
              <span><%= name %></span><span><%= count %></span>
            </div>
            <div class="h-2 rounded-full bg-slate-100 dark:bg-slate-800">
              <div class="h-2 rounded-full bg-teal-600" style="width: <%= (count.to_f / max * 100).round %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 dark:border-slate-700 dark:bg-slate-900">
      <h2 class="text-sm font-semibold text-slate-800 dark:text-slate-100"><%= t("reports.index.salary_distribution") %></h2>
      <div class="mt-4 space-y-3">
        <% max_sal = [@salary[:distribution].values.max.to_i, 1].max %>
        <% @salary[:distribution].each do |label, count| %>
          <div>
            <div class="mb-1 flex justify-between text-xs text-slate-600 dark:text-slate-400">
              <span><%= label %></span><span><%= count %></span>
            </div>
            <div class="h-2 rounded-full bg-slate-100 dark:bg-slate-800">
              <div class="h-2 rounded-full bg-slate-700 dark:bg-teal-500" style="width: <%= (count.to_f / max_sal * 100).round %>%"></div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</div>
