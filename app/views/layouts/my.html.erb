<% content_for :content do %>
  <div class="flex min-h-full flex-col">
    <div class="sticky top-0 z-20 -mx-4 mb-6 border-b border-slate-200 bg-slate-50/95 px-4 py-3 backdrop-blur dark:border-slate-800 dark:bg-slate-950/95 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
      <p class="mb-2 text-xs font-medium uppercase tracking-widest text-teal-700/80 dark:text-teal-400/80"><%= t("my.workspace") %></p>
      <%= render "my/subnav" %>
    </div>

    <%= turbo_frame_tag "my_content", class: "block min-w-0" do %>
      <% if notice = flash[:notice] %>
        <p class="mb-4 rounded-md border border-teal-200 bg-teal-50 px-4 py-2 text-sm text-teal-900 dark:border-teal-800 dark:bg-teal-950 dark:text-teal-100"><%= notice %></p>
      <% end %>
      <% if alert = flash[:alert] %>
        <p class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-800 dark:border-red-900 dark:bg-red-950 dark:text-red-200"><%= alert %></p>
      <% end %>
      <%= yield %>
    <% end %>
  </div>
<% end %>
<%= render template: "layouts/application" %>
