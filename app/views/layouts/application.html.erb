<!DOCTYPE html>
<html class="h-full bg-slate-50 dark:bg-slate-950" lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "EMS" %> · Employee Management</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Employee Management System">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      (function () {
        try {
          if (localStorage.getItem("ems-theme") === "dark") {
            document.documentElement.classList.add("dark");
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body class="h-full font-sans text-slate-800 antialiased dark:text-slate-100">
    <% if authenticated? && current_company %>
      <div class="flex h-dvh overflow-hidden">
        <aside class="hidden h-full w-60 shrink-0 flex-col bg-slate-900 text-slate-300 lg:flex">
          <div class="shrink-0 px-5 py-6 border-b border-slate-800">
            <p class="text-xs uppercase tracking-widest text-teal-400/90 font-medium">EMS</p>
            <p class="mt-1 text-white font-semibold truncate"><%= current_company.name %></p>
          </div>
          <%= render "shared/company_switcher" %>
          <div class="shrink-0">
            <%= render "shared/global_search" %>
          </div>
          <nav class="min-h-0 flex-1 overflow-y-auto px-3 py-4 space-y-1">
            <%= render "shared/nav_link", path: root_path, label: t("nav.dashboard"), active: controller_name == "dashboard" && !controller_path.start_with?("my/") %>
            <% if Current.employee %>
              <%= render "shared/nav_link", path: my_dashboard_path, label: t("nav.my_workspace"), active: controller_path.start_with?("my/") %>
            <% end %>
            <%= render "shared/nav_link", path: employees_path, label: t("nav.employees"), active: controller_name == "employees" %>
            <%= render "shared/nav_link", path: departments_path, label: t("nav.departments"), active: controller_name == "departments" %>
            <% if policy(Office).index? %>
              <%= render "shared/nav_link", path: offices_path, label: t("nav.offices"), active: controller_name == "offices" %>
            <% end %>
            <% if policy(Team).index? %>
              <%= render "shared/nav_link", path: teams_path, label: t("nav.teams"), active: controller_name == "teams" %>
            <% end %>
            <%= render "shared/nav_link", path: attendance_days_path, label: t("nav.attendance"), active: controller_path.start_with?("attendance") %>
            <%= render "shared/nav_link", path: timesheets_path, label: t("nav.timesheets"), active: controller_name == "timesheets" %>
            <%= render "shared/nav_link", path: leave_requests_path, label: t("nav.leave"), active: controller_name == "leave_requests" %>
            <%= render "shared/nav_link", path: review_cycles_path, label: t("nav.performance"), active: %w[review_cycles performance_reviews goals].include?(controller_name) %>
            <%= render "shared/nav_link", path: company_assets_path, label: t("nav.assets"), active: controller_name == "company_assets" %>
            <%= render "shared/nav_link", path: employee_documents_path, label: t("nav.documents"), active: controller_name == "employee_documents" %>
            <%= render "shared/platform_nav" %>
          </nav>
          <div class="shrink-0 px-4 py-4 border-t border-slate-800 text-sm space-y-2">
            <p class="text-slate-400 truncate"><%= current_user&.full_name %></p>
            <%= render "shared/locale_and_theme" %>
            <%= link_to t("nav.security_mfa"), mfa_path, class: "block text-teal-400 hover:text-teal-300" %>
            <%= button_to t("nav.sign_out"), session_path, method: :delete, class: "text-teal-400 hover:text-teal-300" %>
          </div>
        </aside>

        <div class="flex min-h-0 min-w-0 flex-1 flex-col overflow-y-auto">
          <header class="lg:hidden flex items-center justify-between gap-3 px-4 py-3 bg-slate-900 text-white">
            <span class="font-semibold"><%= current_company.name %></span>
            <%= button_to t("nav.sign_out"), session_path, method: :delete, class: "text-sm text-teal-300" %>
          </header>
          <nav class="lg:hidden flex gap-1 overflow-x-auto px-3 py-2 bg-white border-b border-slate-200 text-sm dark:bg-slate-900 dark:border-slate-800">
            <%= link_to t("nav.dashboard"), root_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'dashboard' && !controller_path.start_with?('my/') ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <% if Current.employee %>
              <%= link_to t("nav.my_workspace"), my_dashboard_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_path.start_with?('my/') ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <% end %>
            <%= link_to t("nav.employees"), employees_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'employees' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <%= link_to t("nav.departments"), departments_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'departments' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <% if policy(Office).index? %>
              <%= link_to t("nav.offices"), offices_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'offices' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <% end %>
            <% if policy(Team).index? %>
              <%= link_to t("nav.teams"), teams_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'teams' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <% end %>
            <%= link_to t("nav.attendance"), attendance_days_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_path.start_with?('attendance') ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <%= link_to t("nav.leave"), leave_requests_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'leave_requests' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <%= link_to t("nav.performance"), review_cycles_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{%w[review_cycles performance_reviews goals].include?(controller_name) ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <%= link_to t("nav.assets"), company_assets_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'company_assets' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <%= link_to t("nav.documents"), employee_documents_path, class: "px-3 py-1.5 rounded-md whitespace-nowrap #{controller_name == 'employee_documents' ? 'bg-teal-50 text-teal-800' : 'text-slate-600 dark:text-slate-300'}" %>
            <%= render "shared/platform_mobile_nav" %>
          </nav>

          <main class="flex-1 px-4 py-6 sm:px-6 lg:px-8 dark:bg-slate-950">
            <% unless controller_path.start_with?("my/") %>
              <% if notice = flash[:notice] %>
                <p class="mb-4 rounded-md border border-teal-200 bg-teal-50 px-4 py-2 text-sm text-teal-900 dark:border-teal-800 dark:bg-teal-950 dark:text-teal-100" id="notice"><%= notice %></p>
              <% end %>
              <% if alert = flash[:alert] %>
                <p class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-800 dark:border-red-900 dark:bg-red-950 dark:text-red-200" id="alert"><%= alert %></p>
              <% end %>
            <% end %>
            <%= content_for?(:content) ? yield(:content) : yield %>
          </main>
        </div>
      </div>
    <% else %>
      <main class="min-h-full flex items-center justify-center px-4 py-12 bg-gradient-to-br from-slate-100 via-slate-50 to-teal-50 dark:from-slate-950 dark:via-slate-900 dark:to-slate-950">
        <div class="w-full max-w-md">
          <% if notice = flash[:notice] %>
            <p class="mb-4 rounded-md border border-teal-200 bg-teal-50 px-4 py-2 text-sm text-teal-900" id="notice"><%= notice %></p>
          <% end %>
          <% if alert = flash[:alert] %>
            <p class="mb-4 rounded-md border border-red-200 bg-red-50 px-4 py-2 text-sm text-red-800" id="alert"><%= alert %></p>
          <% end %>
          <%= yield %>
        </div>
      </main>
    <% end %>
  </body>
</html>
