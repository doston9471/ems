<div class="space-y-6">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("documents.index.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("documents.index.subtitle") %></p>
    </div>
    <% if policy(EmployeeDocument).create? %>
      <%= link_to t("documents.index.new"), new_employee_document_path, class: "inline-flex rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <% end %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.employee") %></th>
          <th class="px-4 py-3"><%= t("common.title") %></th>
          <th class="px-4 py-3"><%= t("common.type") %></th>
          <th class="px-4 py-3"><%= t("common.status") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @employee_documents.each do |document| %>
          <tr class="hover:bg-slate-50">
            <td class="px-4 py-3"><%= document.employee.full_name %></td>
            <td class="px-4 py-3"><%= link_to document.title, employee_document_path(document), class: "font-medium text-teal-700 hover:text-teal-800" %></td>
            <td class="px-4 py-3"><%= document.doc_type.humanize %></td>
            <td class="px-4 py-3"><%= document.status.humanize %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @employee_documents.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("documents.index.empty") %></p>
    <% end %>
  </div>
</div>
