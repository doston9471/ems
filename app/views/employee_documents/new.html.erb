<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= t("documents.new.title") %></h1>

  <%= form_with model: @employee_document, multipart: true, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if @employee_document.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= @employee_document.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :employee_id, t("common.employee"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :employee_id, @employees, :id, :full_name, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :title, t("common.title"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :doc_type, t("common.doc_type"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.select :doc_type, EmployeeDocument.doc_types.keys.map { |k| [k.humanize, k] }, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :file, t("documents.new.initial_file"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.file_field :file, accept: ".pdf,.png,.jpg,.jpeg,.gif,.webp,.doc,.docx", class: "mt-1 block w-full text-sm text-slate-600" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit t("documents.new.submit"), class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("common.cancel"), employee_documents_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
