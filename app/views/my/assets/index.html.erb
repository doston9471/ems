<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.assets.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("my.assets.subtitle") %></p>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("my.assets.asset") %></th>
          <th class="px-4 py-3"><%= t("common.type") %></th>
          <th class="px-4 py-3"><%= t("my.assets.assigned") %></th>
          <th class="px-4 py-3"><%= t("my.assets.returned") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @assignments.each do |assignment| %>
          <tr>
            <td class="px-4 py-3 font-medium"><%= assignment.company_asset.name %></td>
            <td class="px-4 py-3"><%= assignment.company_asset.asset_type.humanize %></td>
            <td class="px-4 py-3"><%= assignment.assigned_on %></td>
            <td class="px-4 py-3"><%= assignment.returned_on || t("my.assets.active") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @assignments.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("my.assets.empty") %></p>
    <% end %>
  </div>
</div>
