<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">My team</h1>
    <p class="mt-1 text-sm text-slate-500">Manager, reports, and team memberships.</p>
  </div>

  <div class="grid gap-4 lg:grid-cols-2">
    <section class="rounded-lg border border-slate-200 bg-white p-5 text-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Manager</p>
      <p class="mt-2 text-lg font-semibold text-slate-900"><%= @manager&.full_name || "—" %></p>
      <% if @manager %>
        <p class="text-slate-500"><%= @manager.job_title.presence || "Manager" %></p>
      <% end %>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white p-5 text-sm">
      <p class="text-xs uppercase tracking-wide text-slate-500">Org chart</p>
      <p class="mt-2 text-slate-600">See where you sit in the company tree.</p>
      <p class="mt-3">
        <%= link_to "Open org chart (highlight me)", org_chart_path(highlight: @employee.id), data: { turbo_frame: "_top" }, class: "text-teal-700 hover:text-teal-800" %>
      </p>
    </section>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900">Direct reports (<%= @direct_reports.size %>)</h2>
    <ul class="mt-3 divide-y divide-slate-100 text-sm">
      <% @direct_reports.each do |report| %>
        <li class="flex justify-between gap-2 py-2">
          <span class="font-medium"><%= report.full_name %></span>
          <span class="text-slate-500"><%= report.job_title.presence || "—" %></span>
        </li>
      <% end %>
      <% if @direct_reports.empty? %><li class="py-2 text-slate-500">No direct reports.</li><% end %>
    </ul>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900">Teams</h2>
    <ul class="mt-3 space-y-2 text-sm">
      <% @teams.each do |team| %>
        <li><%= team.name %><% if team.department %> · <%= team.department.name %><% end %><% if team.lead_employee_id == @employee.id %> · lead<% end %></li>
      <% end %>
      <% @led_teams.each do |team| %>
        <% next if @teams.include?(team) %>
        <li><%= team.name %> · lead</li>
      <% end %>
      <% if @teams.empty? && @led_teams.empty? %><li class="text-slate-500">Not on a team yet.</li><% end %>
    </ul>
  </section>
</div>
