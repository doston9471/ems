<div class="mx-auto max-w-lg space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.notify_prefs.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("my.notify_prefs.subtitle") %></p>
  </div>

  <%= form_with url: my_notification_preferences_path, method: :patch, class: "rounded-lg border border-slate-200 bg-white p-5 space-y-4" do %>
    <% @channels.each do |channel| %>
      <label class="flex items-center justify-between gap-3 text-sm">
        <span class="font-medium text-slate-800"><%= channel.humanize %></span>
        <%= check_box_tag "preferences[#{channel}]", "1", @user.notification_channel_enabled?(channel), class: "rounded border-slate-300" %>
      </label>
    <% end %>
    <%= submit_tag t("my.notify_prefs.save"), class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
  <% end %>
</div>
