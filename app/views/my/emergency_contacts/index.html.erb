<div class="space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.contacts.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("my.contacts.subtitle") %></p>
    </div>
    <%= link_to t("my.contacts.add"), new_my_emergency_contact_path, class: "rounded-md bg-teal-700 px-3 py-1.5 text-sm font-medium text-white hover:bg-teal-600" %>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.name") %></th>
          <th class="px-4 py-3"><%= t("my.contacts.relationship") %></th>
          <th class="px-4 py-3"><%= t("my.contacts.phone") %></th>
          <th class="px-4 py-3"><%= t("common.email") %></th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @contacts.each do |contact| %>
          <tr>
            <td class="px-4 py-3 font-medium"><%= contact.name %><% if contact.primary %> <span class="text-xs text-teal-700"><%= t("my.contacts.primary") %></span><% end %></td>
            <td class="px-4 py-3"><%= contact.relationship.presence || t("common.empty_value") %></td>
            <td class="px-4 py-3"><%= contact.phone.presence || t("common.empty_value") %></td>
            <td class="px-4 py-3"><%= contact.email.presence || t("common.empty_value") %></td>
            <td class="px-4 py-3 text-right space-x-2">
              <%= link_to t("common.edit"), edit_my_emergency_contact_path(contact), class: "text-teal-700 hover:text-teal-800" %>
              <%= button_to t("my.contacts.remove"), my_emergency_contact_path(contact), method: :delete, form: { data: { turbo_confirm: t("my.contacts.remove_confirm") } }, class: "inline text-rose-600 hover:text-rose-700" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @contacts.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("my.contacts.empty") %></p>
    <% end %>
  </div>
</div>
