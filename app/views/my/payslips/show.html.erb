<div class="mx-auto max-w-2xl space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900">Payslip</h1>
      <p class="mt-1 text-sm text-slate-500"><%= @payslip.payroll_run.period_start %> → <%= @payslip.payroll_run.period_end %></p>
    </div>
    <%= link_to "Download PDF", my_payslip_path(@payslip, format: :pdf), data: { turbo: false }, class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
  </div>

  <dl class="grid gap-4 rounded-lg border border-slate-200 bg-white p-5 sm:grid-cols-2 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Salary</dt>
      <dd class="mt-1"><%= number_to_currency(@payslip.salary_cents / 100.0, unit: "#{@payslip.currency} ") %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Bonus</dt>
      <dd class="mt-1"><%= number_to_currency(@payslip.bonus_cents / 100.0, unit: "#{@payslip.currency} ") %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Tax</dt>
      <dd class="mt-1"><%= number_to_currency(@payslip.tax_cents / 100.0, unit: "#{@payslip.currency} ") %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Insurance</dt>
      <dd class="mt-1"><%= number_to_currency(@payslip.insurance_cents / 100.0, unit: "#{@payslip.currency} ") %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="text-xs uppercase tracking-wide text-slate-500">Net pay</dt>
      <dd class="mt-1 text-lg font-semibold"><%= number_to_currency(@payslip.net_cents / 100.0, unit: "#{@payslip.currency} ") %></dd>
    </div>
  </dl>

  <p><%= link_to "← My payslips", my_payslips_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
