<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">Upcoming</h1>
    <p class="mt-1 text-sm text-slate-500">Interviews you're conducting and related calendar syncs.</p>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900">Interviews</h2>
    <ul class="mt-3 divide-y divide-slate-100 text-sm">
      <% @interviews.each do |interview| %>
        <li class="flex flex-wrap items-center justify-between gap-2 py-2">
          <div>
            <p class="font-medium"><%= interview.applicant.full_name %></p>
            <p class="text-xs text-slate-500"><%= interview.mode.humanize %> · <%= interview.scheduled_at.strftime("%Y-%m-%d %H:%M") %></p>
          </div>
          <span class="text-slate-500"><%= interview.status.humanize %></span>
        </li>
      <% end %>
      <% if @interviews.empty? %><li class="py-2 text-slate-500">No upcoming interviews.</li><% end %>
    </ul>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900">Calendar sync activity</h2>
    <ul class="mt-3 divide-y divide-slate-100 text-sm">
      <% @calendar_events.each do |event| %>
        <li class="flex flex-wrap items-center justify-between gap-2 py-2">
          <div>
            <p class="font-medium"><%= event.eventable_type.underscore.humanize %> #<%= event.eventable_id %></p>
            <p class="text-xs text-slate-500"><%= event.provider.humanize %> · <%= event.status.humanize %></p>
          </div>
          <span class="text-slate-500"><%= event.synced_at&.strftime("%Y-%m-%d %H:%M") || event.updated_at.strftime("%Y-%m-%d") %></span>
        </li>
      <% end %>
      <% if @calendar_events.empty? %><li class="py-2 text-slate-500">No calendar events linked to you yet.</li><% end %>
    </ul>
  </section>
</div>
