<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.reviews.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("my.reviews.subtitle") %></p>
  </div>

  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white">
    <table class="min-w-full divide-y divide-slate-200 text-sm">
      <thead class="bg-slate-50 text-left text-xs uppercase tracking-wide text-slate-500">
        <tr>
          <th class="px-4 py-3"><%= t("common.employee") %></th>
          <th class="px-4 py-3"><%= t("my.reviews.reviewer") %></th>
          <th class="px-4 py-3"><%= t("common.type") %></th>
          <th class="px-4 py-3"><%= t("my.reviews.cycle") %></th>
          <th class="px-4 py-3"><%= t("common.status") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @performance_reviews.each do |review| %>
          <tr>
            <td class="px-4 py-3"><%= link_to review.employee.full_name, my_performance_review_path(review), class: "font-medium text-teal-700 hover:text-teal-800" %></td>
            <td class="px-4 py-3"><%= review.reviewer.full_name %></td>
            <td class="px-4 py-3"><%= review.review_type.humanize %></td>
            <td class="px-4 py-3"><%= review.review_cycle.name %></td>
            <td class="px-4 py-3"><%= review.status.humanize %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <% if @performance_reviews.empty? %>
      <p class="px-4 py-8 text-center text-sm text-slate-500"><%= t("my.reviews.empty") %></p>
    <% end %>
  </div>
</div>
