<div class="mx-auto max-w-2xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">Performance review</h1>
    <p class="mt-1 text-sm text-slate-500"><%= @performance_review.employee.full_name %> · <%= @performance_review.review_type.humanize %> by <%= @performance_review.reviewer.full_name %></p>
  </div>

  <dl class="grid gap-4 rounded-lg border border-slate-200 bg-white p-5 sm:grid-cols-2 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Cycle</dt>
      <dd class="mt-1"><%= @performance_review.review_cycle.name %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Status</dt>
      <dd class="mt-1"><%= @performance_review.status.humanize %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Overall rating</dt>
      <dd class="mt-1"><%= @performance_review.overall_rating.presence || "—" %></dd>
    </div>
  </dl>

  <% if @review_feedbacks.any? %>
    <div class="space-y-3">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500">Feedback</h2>
      <% @review_feedbacks.each do |feedback| %>
        <div class="rounded-lg border border-slate-200 bg-white p-4 text-sm">
          <p class="font-medium text-slate-800"><%= feedback.author_employee.full_name %><% if feedback.rating.present? %> · <%= feedback.rating %>/5<% end %></p>
          <p class="mt-2 text-slate-600"><%= feedback.body %></p>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if policy(@performance_review).submit? %>
    <%= form_with url: submit_my_performance_review_path(@performance_review), method: :post, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do %>
      <h2 class="text-sm font-semibold text-slate-900">Submit review</h2>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="performance_review_overall_rating">Overall rating</label>
        <input type="number" step="0.1" min="0" max="5" name="performance_review[overall_rating]" id="performance_review_overall_rating" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="performance_review_body">Feedback</label>
        <textarea name="performance_review[body]" id="performance_review_body" rows="4" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm"></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700" for="performance_review_rating">Feedback rating</label>
        <input type="number" step="0.1" min="0" max="5" name="performance_review[rating]" id="performance_review_rating" class="mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm">
      </div>
      <button type="submit" class="rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600">Submit review</button>
    <% end %>
  <% end %>

  <p><%= link_to "← My reviews", my_performance_reviews_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
