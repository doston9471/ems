<div class="space-y-6">
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.inbox.title") %></h1>
      <p class="mt-1 text-sm text-slate-500"><%= t("my.inbox.subtitle") %></p>
    </div>
    <%= button_to t("my.inbox.mark_all_read"), mark_all_read_my_notifications_path, method: :post, class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
  </div>

  <ul class="divide-y divide-slate-100 overflow-hidden rounded-lg border border-slate-200 bg-white text-sm">
    <% @notifications.each do |note| %>
      <li class="flex flex-wrap items-center justify-between gap-3 px-4 py-3 <%= note.unread? ? 'bg-teal-50/50' : '' %>">
        <div>
          <p class="font-medium text-slate-900"><%= note.event_key.tr(".", " ").humanize %></p>
          <p class="text-xs text-slate-500"><%= note.created_at.strftime("%Y-%m-%d %H:%M") %> · <%= note.status %></p>
        </div>
        <% if note.unread? %>
          <%= button_to t("my.inbox.mark_read"), mark_read_my_notification_path(note), method: :post, class: "text-teal-700 hover:text-teal-800" %>
        <% else %>
          <span class="text-xs text-slate-400"><%= t("my.inbox.read") %></span>
        <% end %>
      </li>
    <% end %>
    <% if @notifications.empty? %>
      <li class="px-4 py-8 text-center text-slate-500"><%= t("my.inbox.empty") %></li>
    <% end %>
  </ul>
</div>
