<div class="mx-auto max-w-2xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900">Leave request</h1>
    <p class="mt-1 text-sm text-slate-500"><%= @leave_request.leave_type.name %> · <%= @leave_request.status.humanize %></p>
  </div>

  <dl class="grid gap-4 rounded-lg border border-slate-200 bg-white p-5 sm:grid-cols-2 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Dates</dt>
      <dd class="mt-1"><%= @leave_request.start_on %> → <%= @leave_request.end_on %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Days</dt>
      <dd class="mt-1"><%= @leave_request.days %></dd>
    </div>
    <div class="sm:col-span-2">
      <dt class="text-xs uppercase tracking-wide text-slate-500">Reason</dt>
      <dd class="mt-1"><%= @leave_request.reason.presence || "—" %></dd>
    </div>
  </dl>

  <p><%= link_to "← My leave", my_leave_requests_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
