<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= t("leave.new.title") %></h1>

  <%= form_with model: @leave_request, url: my_leave_requests_path, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if @leave_request.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= @leave_request.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :leave_type_id, t("leave.new.leave_type"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :leave_type_id, @leave_types, :id, :name, {}, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div>
        <%= f.label :start_on, t("common.start_on"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.date_field :start_on, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= f.label :end_on, t("common.end_on"), class: "block text-sm font-medium text-slate-700" %>
        <%= f.date_field :end_on, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
      </div>
    </div>
    <div>
      <%= f.label :days, t("common.days"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.number_field :days, step: 0.5, min: 0.5, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :reason, t("common.reason"), class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_area :reason, rows: 3, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>

    <div class="flex gap-3">
      <%= f.submit t("leave.new.submit"), class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to t("common.cancel"), my_leave_requests_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600" %>
    </div>
  <% end %>
</div>
