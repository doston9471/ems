<div class="mx-auto max-w-2xl space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= @document.title %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= @document.doc_type.humanize %> · <%= @document.status.humanize %></p>
  </div>

  <div class="rounded-lg border border-slate-200 bg-white p-5 text-sm">
    <p class="text-xs uppercase tracking-wide text-slate-500">Versions</p>
    <ul class="mt-3 space-y-2">
      <% @document.document_versions.order(version_number: :desc).each do |version| %>
        <li class="flex items-center justify-between gap-2">
          <span>v<%= version.version_number %><% if version.change_note.present? %> · <%= version.change_note %><% end %></span>
          <% if version.file.attached? %>
            <%= link_to "Download", rails_blob_path(version.file, disposition: "attachment"), data: { turbo: false }, class: "text-teal-700 hover:text-teal-800" %>
          <% end %>
        </li>
      <% end %>
      <% if @document.document_versions.empty? %>
        <li class="text-slate-500">No uploaded versions.</li>
      <% end %>
    </ul>
  </div>

  <p><%= link_to "← My documents", my_documents_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
</div>
