<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.objectives.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= t("my.objectives.subtitle") %></p>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900"><%= t("my.objectives.goals") %></h2>
    <ul class="mt-3 divide-y divide-slate-100 text-sm">
      <% @goals.each do |goal| %>
        <li class="flex items-center justify-between gap-3 py-2">
          <div>
            <p class="font-medium"><%= goal.title %></p>
            <p class="text-xs text-slate-500"><%= goal.status.humanize %><% if goal.target_date %> · <%= t("my.objectives.due", date: goal.target_date) %><% end %></p>
          </div>
          <span class="text-slate-700"><%= goal.progress_percent %>%</span>
        </li>
      <% end %>
      <% if @goals.empty? %><li class="py-2 text-slate-500"><%= t("my.objectives.no_goals") %></li><% end %>
    </ul>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900"><%= t("my.objectives.okrs") %></h2>
    <ul class="mt-3 space-y-4 text-sm">
      <% @okrs.each do |okr| %>
        <li class="rounded-md bg-slate-50 px-3 py-3">
          <p class="font-medium"><%= okr.objective %></p>
          <p class="text-xs text-slate-500">Q<%= okr.quarter %> <%= okr.year %> · <%= okr.status.humanize %></p>
          <% if okr.key_results.any? %>
            <ul class="mt-2 space-y-1 text-xs text-slate-600">
              <% okr.key_results.each do |kr| %>
                <li><%= kr.title %>: <%= kr.current_value %>/<%= kr.target_value %> <%= kr.unit %></li>
              <% end %>
            </ul>
          <% end %>
        </li>
      <% end %>
      <% if @okrs.empty? %><li class="text-slate-500"><%= t("my.objectives.no_okrs") %></li><% end %>
    </ul>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <h2 class="text-sm font-semibold text-slate-900"><%= t("my.objectives.kpis") %></h2>
    <div class="mt-3 overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead class="text-left text-xs uppercase tracking-wide text-slate-500">
          <tr>
            <th class="py-2 pr-4"><%= t("common.name") %></th>
            <th class="py-2 pr-4"><%= t("my.objectives.period") %></th>
            <th class="py-2 pr-4"><%= t("my.objectives.current") %></th>
            <th class="py-2"><%= t("my.objectives.target") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @kpis.each do |kpi| %>
            <tr>
              <td class="py-2 pr-4 font-medium"><%= kpi.name %></td>
              <td class="py-2 pr-4"><%= kpi.period %></td>
              <td class="py-2 pr-4"><%= kpi.current_value %> <%= kpi.unit %></td>
              <td class="py-2"><%= kpi.target_value %> <%= kpi.unit %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
      <% if @kpis.empty? %><p class="text-sm text-slate-500"><%= t("my.objectives.no_kpis") %></p><% end %>
    </div>
  </section>
</div>
