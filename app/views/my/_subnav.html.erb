<%# locals: () %>
<nav
  class="flex flex-wrap gap-1.5 text-sm"
  data-controller="my-nav"
  data-action="turbo:frame-load@document->my-nav#sync turbo:morph@document->my-nav#sync"
>
  <%
    items = [
      [ t("my.nav.overview"), my_dashboard_path, -> { controller_name == "dashboard" } ],
      [ t("my.nav.attendance"), my_attendance_path, -> { controller_name == "attendance" } ],
      [ t("my.nav.leave"), my_leave_requests_path, -> { controller_name == "leave_requests" } ],
      [ t("my.nav.reviews"), my_performance_reviews_path, -> { controller_name == "performance_reviews" } ],
      [ t("my.nav.payslips"), my_payslips_path, -> { controller_name == "payslips" } ],
      [ t("my.nav.objectives"), my_objectives_path, -> { controller_name == "objectives" } ],
      [ t("my.nav.documents"), my_documents_path, -> { controller_name == "documents" } ],
      [ t("my.nav.assets"), my_assets_path, -> { controller_name == "assets" } ],
      [ t("my.nav.team"), my_team_path, -> { controller_name == "team" } ],
      [ t("my.nav.upcoming"), my_upcoming_path, -> { controller_name == "upcoming" } ],
      [ t("my.nav.contacts"), my_emergency_contacts_path, -> { controller_name == "emergency_contacts" } ],
      [ t("my.nav.inbox"), my_notifications_path, -> { controller_name == "notifications" } ],
      [ t("my.nav.notify_prefs"), edit_my_notification_preferences_path, -> { controller_name == "notification_preferences" } ]
    ]
  %>
  <% items.each do |label, path, active_proc| %>
    <%= link_to label, path,
          data: { turbo_frame: "my_content", turbo_action: "advance", my_nav_target: "link" },
          class: my_nav_class(active_proc.call) %>
  <% end %>
</nav>
