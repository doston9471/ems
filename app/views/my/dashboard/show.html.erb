<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900"><%= t("my.dashboard.title") %></h1>
    <p class="mt-1 text-sm text-slate-500"><%= @employee.full_name %> · <%= @employee.job_title.presence || t("my.dashboard.employee_fallback") %></p>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white p-5">
    <div class="flex flex-wrap items-start justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.todays_actions") %></p>
        <p class="mt-1 text-sm text-slate-700">
          <%= @today ? "#{@today.status.humanize} · #{t('common.in')} #{@today.clock_in_at&.strftime('%H:%M') || t('common.empty_value')} · #{t('common.out')} #{@today.clock_out_at&.strftime('%H:%M') || t('common.empty_value')}" : t("my.dashboard.not_clocked_in") %>
        </p>
      </div>
      <% if @can_clock %>
        <div class="flex flex-wrap gap-2">
          <% unless @today&.clock_in_at %>
            <%= button_to t("attendance.index.clock_in"), clock_in_my_attendance_path, method: :post, class: "rounded-md bg-teal-700 px-3 py-1.5 text-sm font-medium text-white hover:bg-teal-600" %>
          <% end %>
          <% if @today&.clock_in_at && @today.clock_out_at.blank? %>
            <%= button_to t("attendance.my.start_break"), break_start_my_attendance_path, method: :post, class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
            <%= button_to t("attendance.my.end_break"), break_end_my_attendance_path, method: :post, class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
            <%= button_to t("attendance.index.clock_out"), clock_out_my_attendance_path, method: :post, class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
          <% end %>
        </div>
      <% end %>
    </div>
    <div class="mt-4 flex flex-wrap gap-2">
      <%= link_to t("my.dashboard.request_leave"), new_my_leave_request_path, class: "rounded-md border border-slate-300 px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
      <% if @pending_reviews.any? %>
        <%= link_to t("my.dashboard.submit_review", count: @pending_reviews.size), my_performance_review_path(@pending_reviews.first), class: "rounded-md bg-teal-700 px-3 py-1.5 text-sm font-medium text-white hover:bg-teal-600" %>
      <% end %>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-3">
    <div class="rounded-lg border border-slate-200 bg-white p-5 lg:col-span-2">
      <div class="flex items-center justify-between gap-2">
        <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.action_inbox") %></p>
        <%= link_to t("my.dashboard.all_notifications"), my_notifications_path, class: "text-xs text-teal-700 hover:text-teal-800" %>
      </div>
      <ul class="mt-3 space-y-2 text-sm">
        <% @pending_reviews.each do |review| %>
          <li class="flex items-center justify-between gap-2 rounded-md bg-amber-50 px-3 py-2">
            <span><%= t("my.dashboard.review_pending", name: review.employee.full_name, type: review.review_type.humanize) %></span>
            <%= link_to t("my.dashboard.open"), my_performance_review_path(review), class: "text-teal-700 hover:text-teal-800" %>
          </li>
        <% end %>
        <% @awaiting_leave.each do |leave| %>
          <li class="flex items-center justify-between gap-2 rounded-md bg-slate-50 px-3 py-2">
            <span><%= t("my.dashboard.leave_awaiting", type: leave.leave_type.name, status: leave.status.humanize) %></span>
            <%= link_to t("my.dashboard.view"), my_leave_request_path(leave), class: "text-teal-700 hover:text-teal-800" %>
          </li>
        <% end %>
        <% @unread_notifications.each do |note| %>
          <li class="flex items-center justify-between gap-2 rounded-md bg-teal-50 px-3 py-2">
            <span><%= note.event_key.tr(".", " ").humanize %></span>
            <%= button_to t("my.dashboard.mark_read"), mark_read_my_notification_path(note), method: :post, class: "text-teal-700 hover:text-teal-800" %>
          </li>
        <% end %>
        <% if @pending_reviews.empty? && @awaiting_leave.empty? && @unread_notifications.empty? %>
          <li class="text-slate-500"><%= t("my.dashboard.caught_up") %></li>
        <% end %>
      </ul>
    </div>

    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.profile") %></p>
      <dl class="mt-3 space-y-2 text-sm">
        <div><dt class="text-slate-500"><%= t("my.dashboard.department") %></dt><dd class="font-medium"><%= @employee.department&.name || t("common.empty_value") %></dd></div>
        <div><dt class="text-slate-500"><%= t("my.dashboard.office") %></dt><dd class="font-medium"><%= @employee.office&.name || t("common.empty_value") %></dd></div>
        <div><dt class="text-slate-500"><%= t("my.dashboard.manager") %></dt><dd class="font-medium"><%= @employee.manager&.full_name || t("common.empty_value") %></dd></div>
        <div><dt class="text-slate-500"><%= t("my.dashboard.teams") %></dt><dd class="font-medium"><%= @employee.teams.map(&:name).presence&.to_sentence || t("common.empty_value") %></dd></div>
        <div><dt class="text-slate-500"><%= t("my.dashboard.joined") %></dt><dd class="font-medium"><%= @employee.joining_date || t("common.empty_value") %></dd></div>
        <div><dt class="text-slate-500"><%= t("my.dashboard.status") %></dt><dd class="font-medium"><%= @employee.employment_status.humanize %></dd></div>
      </dl>
      <p class="mt-3"><%= link_to t("my.dashboard.view_team"), my_team_path, class: "text-sm text-teal-700 hover:text-teal-800" %></p>
    </div>
  </section>

  <section class="grid gap-4 lg:grid-cols-2">
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.leave_balances") %></p>
      <% if @leave_balances.any? %>
        <div class="mt-3 flex flex-wrap gap-3">
          <% @leave_balances.each do |balance| %>
            <div class="min-w-[7rem] rounded-md bg-slate-50 px-3 py-2">
              <p class="text-xs text-slate-500"><%= balance.leave_type.name %></p>
              <p class="text-lg font-semibold text-slate-900"><%= balance.remaining %></p>
              <p class="text-xs text-slate-500"><%= t("my.dashboard.used_of", used: balance.used, entitled: balance.entitled) %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-3 text-sm text-slate-500"><%= t("my.dashboard.no_balances", year: Date.current.year) %></p>
      <% end %>
    </div>

    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between gap-2">
        <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.week_attendance") %></p>
        <%= link_to t("my.dashboard.details"), my_attendance_path, class: "text-xs text-teal-700 hover:text-teal-800" %>
      </div>
      <div class="mt-4 flex items-end gap-2">
        <% @week_days.each do |entry| %>
          <div class="flex flex-1 flex-col items-center gap-1">
            <div class="h-10 w-full rounded-sm <%= attendance_spark_tone(entry[:day]) %>" title="<%= entry[:date] %>: <%= entry[:day]&.status&.humanize || 'No record' %>"></div>
            <span class="text-[10px] uppercase text-slate-500"><%= entry[:date].strftime("%a") %></span>
          </div>
        <% end %>
      </div>
    </div>
  </section>

  <% if @latest_payslip %>
    <section class="rounded-lg border border-teal-200 bg-teal-50/40 p-5">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="text-xs uppercase tracking-wide text-teal-800/70"><%= t("my.dashboard.latest_payslip") %></p>
          <p class="mt-1 text-lg font-semibold text-slate-900">
            <%= number_to_currency(@latest_payslip.net_cents / 100.0, unit: "#{@latest_payslip.currency} ") %>
            <span class="text-sm font-normal text-slate-500"><%= t("my.dashboard.net_period", start: @latest_payslip.payroll_run.period_start, end: @latest_payslip.payroll_run.period_end) %></span>
          </p>
        </div>
        <div class="flex gap-2">
          <%= link_to t("my.dashboard.view"), my_payslip_path(@latest_payslip), class: "rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm text-slate-700 hover:bg-slate-50" %>
          <%= link_to t("common.download_pdf"), my_payslip_path(@latest_payslip, format: :pdf), data: { turbo: false }, class: "rounded-md bg-teal-700 px-3 py-1.5 text-sm font-medium text-white hover:bg-teal-600" %>
        </div>
      </div>
    </section>
  <% end %>

  <section class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <%= link_to my_attendance_path, class: "rounded-lg border border-slate-200 bg-white p-5 hover:border-teal-300" do %>
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.attendance") %></p>
      <p class="mt-2 text-lg font-semibold text-slate-900"><%= @today&.status&.humanize || t("my.dashboard.not_clocked_in") %></p>
    <% end %>
    <%= link_to my_leave_requests_path, class: "rounded-lg border border-slate-200 bg-white p-5 hover:border-teal-300" do %>
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.leave") %></p>
      <p class="mt-2 text-lg font-semibold text-slate-900"><%= t("my.dashboard.recent_count", count: @leave_requests.size) %></p>
    <% end %>
    <%= link_to my_performance_reviews_path, class: "rounded-lg border border-slate-200 bg-white p-5 hover:border-teal-300" do %>
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.reviews") %></p>
      <p class="mt-2 text-lg font-semibold text-slate-900"><%= t("my.dashboard.recent_count", count: @reviews.size) %></p>
    <% end %>
    <%= link_to my_payslips_path, class: "rounded-lg border border-slate-200 bg-white p-5 hover:border-teal-300" do %>
      <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.payslips") %></p>
      <p class="mt-2 text-lg font-semibold text-slate-900"><%= t("my.dashboard.available_count", count: @payslips.size) %></p>
    <% end %>
  </section>

  <section class="grid gap-4 lg:grid-cols-3">
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between">
        <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.recent_leave") %></p>
        <%= link_to t("my.dashboard.all"), my_leave_requests_path, class: "text-xs text-teal-700" %>
      </div>
      <ul class="mt-3 space-y-2 text-sm">
        <% @leave_requests.each do |leave| %>
          <li><%= link_to "#{leave.leave_type.name} · #{leave.status.humanize}", my_leave_request_path(leave), class: "text-slate-700 hover:text-teal-700" %></li>
        <% end %>
        <% if @leave_requests.empty? %><li class="text-slate-500"><%= t("my.dashboard.no_leave") %></li><% end %>
      </ul>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between">
        <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.recent_reviews") %></p>
        <%= link_to t("my.dashboard.all"), my_performance_reviews_path, class: "text-xs text-teal-700" %>
      </div>
      <ul class="mt-3 space-y-2 text-sm">
        <% @reviews.each do |review| %>
          <li><%= link_to "#{review.review_type.humanize} · #{review.status.humanize}", my_performance_review_path(review), class: "text-slate-700 hover:text-teal-700" %></li>
        <% end %>
        <% if @reviews.empty? %><li class="text-slate-500"><%= t("my.dashboard.no_reviews") %></li><% end %>
      </ul>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5">
      <div class="flex items-center justify-between">
        <p class="text-xs uppercase tracking-wide text-slate-500"><%= t("my.dashboard.recent_payslips") %></p>
        <%= link_to t("my.dashboard.all"), my_payslips_path, class: "text-xs text-teal-700" %>
      </div>
      <ul class="mt-3 space-y-2 text-sm">
        <% @payslips.each do |item| %>
          <li><%= link_to "#{item.payroll_run.period_end} · #{number_to_currency(item.net_cents / 100.0)}", my_payslip_path(item), class: "text-slate-700 hover:text-teal-700" %></li>
        <% end %>
        <% if @payslips.empty? %><li class="text-slate-500"><%= t("my.dashboard.no_payslips") %></li><% end %>
      </ul>
    </div>
  </section>
</div>
