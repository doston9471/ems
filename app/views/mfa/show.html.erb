<div class="mx-auto max-w-lg rounded-xl border border-slate-200 bg-white p-8 shadow-sm">
  <h1 class="text-2xl font-semibold text-slate-900">Two-factor authentication</h1>

  <% if @enabled %>
    <p class="mt-2 text-sm text-slate-500">Authenticator app verification is enabled on your account.</p>

    <%= form_with url: mfa_path, method: :delete, class: "mt-8 space-y-4" do |form| %>
      <div>
        <%= form.label :code, "Authenticator code", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :code, required: true, autocomplete: "one-time-code", inputmode: "numeric", class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-teal-600 focus:outline-none focus:ring-1 focus:ring-teal-600" %>
      </div>
      <%= form.submit "Disable MFA", class: "rounded-md border border-red-300 bg-white px-4 py-2.5 text-sm font-medium text-red-700 hover:bg-red-50 cursor-pointer" %>
    <% end %>
  <% else %>
    <p class="mt-2 text-sm text-slate-500">Scan the QR code with your authenticator app, then enter a code to enable MFA.</p>

    <div class="mt-6 flex justify-center rounded-lg border border-slate-200 bg-slate-50 p-4">
      <%= @qr_svg.html_safe %>
    </div>

    <p class="mt-4 text-center font-mono text-sm tracking-widest text-slate-700"><%= @secret %></p>
    <p class="mt-1 text-center text-xs text-slate-500">Or enter this secret manually</p>

    <%= form_with url: mfa_path, method: :post, class: "mt-8 space-y-4" do |form| %>
      <div>
        <%= form.label :code, "Authenticator code", class: "block text-sm font-medium text-slate-700" %>
        <%= form.text_field :code, required: true, autocomplete: "one-time-code", inputmode: "numeric", autofocus: true, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm focus:border-teal-600 focus:outline-none focus:ring-1 focus:ring-teal-600" %>
      </div>
      <%= form.submit "Enable MFA", class: "rounded-md bg-teal-700 px-4 py-2.5 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
    <% end %>
  <% end %>

  <p class="mt-6 text-sm"><%= link_to "Back to dashboard", root_path, class: "text-teal-700 underline hover:no-underline" %></p>
</div>
