<div class="mx-auto max-w-xl space-y-6">
  <h1 class="text-2xl font-semibold text-slate-900"><%= title %></h1>

  <%= form_with model: department, class: "space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
    <% if department.errors.any? %>
      <div class="rounded-md border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-800">
        <%= department.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :name, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :name, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :code, class: "block text-sm font-medium text-slate-700" %>
      <%= f.text_field :code, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :parent_id, "Parent department", class: "block text-sm font-medium text-slate-700" %>
      <%= f.collection_select :parent_id, @parents, :id, :name, { include_blank: true }, class: "mt-1 block w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
    </div>
    <div class="flex items-center gap-2">
      <%= f.check_box :active, class: "rounded border-slate-300" %>
      <%= f.label :active, class: "text-sm text-slate-700" %>
    </div>

    <div class="flex gap-3 pt-2">
      <%= f.submit class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600 cursor-pointer" %>
      <%= link_to "Cancel", departments_path, class: "rounded-md px-3.5 py-2 text-sm font-medium text-slate-600 hover:text-slate-900" %>
    </div>
  <% end %>
</div>
