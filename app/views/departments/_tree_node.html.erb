<li class="<%= depth.positive? ? 'ml-5 border-l border-slate-200 pl-4' : '' %>">
  <div class="flex flex-wrap items-center justify-between gap-2 rounded-md px-2 py-2 hover:bg-slate-50">
    <div>
      <%= link_to node.department.name, department_path(node.department), class: "font-medium text-slate-900 hover:text-teal-700" %>
      <% if node.department.code.present? %>
        <span class="ml-2 font-mono text-xs text-slate-500"><%= node.department.code %></span>
      <% end %>
      <% unless node.department.active? %>
        <span class="ml-2 rounded-full bg-slate-100 px-2 py-0.5 text-xs text-slate-600"><%= t("common.inactive") %></span>
      <% end %>
    </div>
    <% if policy(node.department).update? %>
      <%= link_to t("common.edit"), edit_department_path(node.department), class: "text-sm text-teal-700 hover:text-teal-800" %>
    <% end %>
  </div>
  <% if node.children.any? %>
    <ul class="mt-1 space-y-1">
      <% node.children.each do |child| %>
        <%= render "tree_node", node: child, depth: depth + 1 %>
      <% end %>
    </ul>
  <% end %>
</li>
