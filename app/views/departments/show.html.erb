<div class="mx-auto max-w-xl space-y-6">
  <div class="flex items-center justify-between gap-3">
    <h1 class="text-2xl font-semibold text-slate-900"><%= @department.name %></h1>
    <% if policy(@department).update? %>
      <%= link_to "Edit", edit_department_path(@department), class: "rounded-md border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    <% end %>
  </div>
  <dl class="rounded-lg border border-slate-200 bg-white p-5 space-y-3 text-sm">
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Code</dt>
      <dd class="mt-1 font-mono"><%= @department.code || "—" %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Parent</dt>
      <dd class="mt-1"><%= @department.parent&.name || "—" %></dd>
    </div>
    <div>
      <dt class="text-xs uppercase tracking-wide text-slate-500">Status</dt>
      <dd class="mt-1"><%= @department.active? ? "Active" : "Inactive" %></dd>
    </div>
  </dl>
</div>
