<%= form_with model: definition, class: "mx-auto max-w-lg space-y-4 rounded-lg border border-slate-200 bg-white p-5" do |f| %>
  <% if definition.errors.any? %>
    <div class="rounded-md border border-rose-200 bg-rose-50 px-3 py-2 text-sm text-rose-800"><%= definition.errors.full_messages.to_sentence %></div>
  <% end %>

  <div>
    <%= f.label :label, class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :label, required: true, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :key, class: "block text-sm font-medium text-slate-700" %>
    <%= f.text_field :key, required: true, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm font-mono" %>
    <p class="mt-1 text-xs text-slate-500"><%= t("custom_fields.form.key_hint") %></p>
  </div>
  <div>
    <%= f.label :field_type, class: "block text-sm font-medium text-slate-700" %>
    <%= f.select :field_type, CustomFieldDefinition::FIELD_TYPES, {}, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div>
    <%= f.label :position, class: "block text-sm font-medium text-slate-700" %>
    <%= f.number_field :position, class: "mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" %>
  </div>
  <div>
    <label class="block text-sm font-medium text-slate-700" for="options_text"><%= t("custom_fields.form.select_choices") %></label>
    <input type="text" name="options_text" id="options_text" value="<%= Array(definition.options['choices']).join(', ') %>" class="mt-1 w-full rounded-md border border-slate-300 px-3 py-2 text-sm" placeholder="<%= t("custom_fields.form.choices_placeholder") %>">
  </div>
  <div class="flex items-center gap-2">
    <%= f.check_box :required, class: "rounded border-slate-300" %>
    <%= f.label :required, class: "text-sm text-slate-700" %>
  </div>
  <%= f.hidden_field :resource_type, value: "Employee" %>

  <div class="flex gap-2">
    <%= f.submit class: "rounded-md bg-teal-700 px-3.5 py-2 text-sm font-medium text-white hover:bg-teal-600" %>
    <%= link_to t("common.cancel"), custom_field_definitions_path, class: "rounded-md border border-slate-300 px-3.5 py-2 text-sm text-slate-700" %>
  </div>
<% end %>
